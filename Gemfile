source "https://rubygems.org"

# GitHub Pages-compatible Jekyll bundle. Pinning to github-pages keeps the
# local build behavior aligned with what GitHub builds in production.
gem "github-pages", group: :jekyll_plugins

# Windows-only: timezone data. Harmless on other platforms.
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]
# Note: `wdm` (the old Windows file watcher) is unmaintained and fails to
# build on modern Ruby. We rely on polling instead — pass `--force_polling`
# to `jekyll serve` if livereload doesn't pick up file changes.
